{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/static-api/home.json",
      "destination": "/fallback-api/home.json"
    },
    {
      "source": "/static-api/series.json",
      "destination": "/fallback-api/series.json"
    },
    {
      "source": "/static-api/search-index.json",
      "destination": "/fallback-api/search-index.json"
    },
    {
      "source": "/static-api/manifest.json",
      "destination": "/fallback-api/manifest.json"
    },
    {
      "source": "/static-api/series/:series",
      "destination": "/fallback-api/series/:series"
    },
    {
      "source": "/truyen/:path*",
      "destination": "/index"
    },
    {
      "source": "/the-loai/:path*",
      "destination": "/index"
    },
    {
      "source": "/admin/:path*",
      "destination": "/index"
    },
    {
      "source": "/gioi-thieu",
      "destination": "/index"
    },
    {
      "source": "/lien-he",
      "destination": "/index"
    },
    {
      "source": "/chinh-sach-noi-dung",
      "destination": "/index"
    },
    {
      "source": "/privacy",
      "destination": "/index"
    }
  ]
}
