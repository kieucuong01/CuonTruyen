# Local server port. Use 54533 to match the current desktop browser session.
PORT=54533

# Canonical public site URL for SEO routes, sitemap, and robots.
# Local:
PUBLIC_SITE_URL=http://localhost:54533
# Production example:
# PUBLIC_SITE_URL=https://your-comic-site.vercel.app

# When the frontend runs on Vercel but images are served by your own machine,
# expose this local server through a stable public URL, then set it here.
# Example: PUBLIC_IMPORTS_BASE_URL=https://comic-api.your-domain.com
PUBLIC_IMPORTS_BASE_URL=

# Allow the deployed frontend to call this local API/image host.
# Local/dev can use *, production should be the exact Vercel domain.
# Example: CORS_ALLOW_ORIGIN=https://your-comic-site.vercel.app
CORS_ALLOW_ORIGIN=*

# Admin login. Required for /api/admin/* and /api/import.
# Do not expose the server without setting all three values.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Internal session token returned after admin login.
ADMIN_TOKEN=

# Basic in-memory rate limits for admin/import/events.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_ADMIN_MAX=60
RATE_LIMIT_EVENTS_MAX=240

# PostgreSQL catalog storage. Leave empty to keep using local data/imports/catalog.json.
# When set, metadata moves to PostgreSQL while images still stay under data/imports/.
# Example: DATABASE_URL=postgres://comic_user:password@127.0.0.1:5432/comic_reader
DATABASE_URL=

# Local/VPS image and catalog runtime folder. Leave empty to use ./data/imports.
# Example on VPS: IMPORT_ROOT=D:\comic-images or /var/lib/comic-reader/imports
IMPORT_ROOT=

# Optional PostgreSQL tuning. Localhost defaults to SSL off; remote hosts default to SSL on.
POSTGRES_POOL_MAX=10
# POSTGRES_SSL=false
# POSTGRES_SSL_REJECT_UNAUTHORIZED=false

# Crawl worker settings. Run `npm run worker:crawl` in a separate terminal/process.
CRAWL_WORKER_POLL_MS=2000
CRAWL_DOMAIN_DELAY_MS=650
CRAWL_IMAGE_RETRIES=2
CRAWL_IMAGE_RETRY_DELAY_MS=500
CRAWL_JOB_MAX_ATTEMPTS=3
CRAWL_JOB_RETRY_DELAY_MS=60000

# Optional scheduled crawl for hot series. Manual per-series schedules work without this.
CRAWL_HOT_AUTO=false
CRAWL_HOT_MIN_SCORE=1000
CRAWL_HOT_LIMIT=10
CRAWL_SCHEDULE_SCAN_MS=60000
CRAWL_SCHEDULE_MAX_CHAPTERS=0
CRAWL_SCHEDULE_MAX_PAGES=0
ADS_ENABLED=true
DONATE_URL=https://example.com/donate
